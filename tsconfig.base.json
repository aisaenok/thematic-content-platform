{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": [
      "@thematic-content-platform/source"
    ],
    "paths": {
      "@thematic-content-platform/content-domain": [
        "./packages/content-domain/src/index.ts"
      ],
      "@thematic-content-platform/content-source": [
        "./packages/content-source/src/index.ts"
      ]
    }
  }
}
